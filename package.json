{
  "name": "polymarket-copy-trading-bot",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/MMT-trade/OpenClaw-Polymarket-Copytrade.git"
  },
  "description": "Polymarket copy trading bot — replicate a target trader's activity in TypeScript/Node",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "dev": "tsx src/index.ts",
    "copy": "tsx src/index.ts",
    "screen:candidates": "tsx scripts/screen-copy-candidates.ts",
    "screen:candidates:proxy": "node --use-env-proxy --import tsx scripts/screen-copy-candidates.ts",
    "test:creds": "tsx scripts/test-credentials.ts",
    "test:order": "tsx scripts/test-order-config.ts",
    "lint": "tsc --noEmit && tsc -p tsconfig.scripts.json"
  },
  "dependencies": {
    "@ethersproject/providers": "^5.7.2",
    "@ethersproject/wallet": "^5.7.0",
    "@polymarket/clob-client-v2": "^1.0.6",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
